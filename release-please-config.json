{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-component-in-tag": true,
  "separator": "-",
  "pull-request-title-pattern": "chore: release ${component} ${version}",
  "plugins": [
    { "type": "cargo-workspace", "merge": false }
  ],
  "packages": {
    "crates/core": {
      "release-type": "rust",
      "package-name": "quantedge-core",
      "component": "quantedge-core",
      "changelog-path": "CHANGELOG.md"
    },
    "crates/ta": {
      "release-type": "rust",
      "package-name": "quantedge-ta",
      "component": "quantedge-ta",
      "changelog-path": "CHANGELOG.md"
    },
    "crates/strategy": {
      "release-type": "rust",
      "package-name": "quantedge-strategy",
      "component": "quantedge-strategy",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "bootstrap-sha": "01b487d0859a9c6060ba989f6ff572b07ba8cb55"
    }
  }
}
